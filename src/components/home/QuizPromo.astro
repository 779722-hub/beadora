---
const cards = [
  {
    href: '/quiz?by=zodiac',
    title: 'По знаку Зодиака',
    text: 'Подбор камня и украшения по вашему астрологическому знаку',
    icon: '♐',
  },
  {
    href: '/quiz?by=birthday',
    title: 'По дате рождения',
    text: 'Личный талисман по числам рождения — матрица судьбы',
    icon: '✦',
  },
  {
    href: '/quiz?by=mood',
    title: 'По настроению',
    text: 'Что нужно сейчас — гармония, сила, любовь или защита?',
    icon: '❤',
  },
];
---
<section class="quiz-promo">
  <div class="container">
    <div class="cards">
      {cards.map((card) => (
        <a class="quiz-card reveal" href={card.href}>
          <span class="icon">{card.icon}</span>
          <h3>{card.title}</h3>
          <p>{card.text}</p>
          <span class="cta">Подобрать <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .quiz-promo {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .quiz-card {
    display: block;
    position: relative;
    padding: 2rem 1.75rem;
    border-radius: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }
  .quiz-card::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    opacity: 0.08;
    transition: opacity 0.2s ease;
  }
  .quiz-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    color: var(--text);
  }
  .quiz-card:hover::before {
    opacity: 0.2;
  }
  .icon {
    font-family: 'Playfair Display', serif;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: var(--accent);
    color: var(--accent-contrast);
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
  }
  h3 {
    margin: 0 0 0.5rem;
    font-size: 1.375rem;
  }
  p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9375rem;
  }
  .cta svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }
  .quiz-card:hover .cta svg {
    transform: translateX(4px);
  }
</style>
