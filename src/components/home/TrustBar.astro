---
const items = [
  { title: 'Натуральные камни', text: '100% природного происхождения', icon: 'gem' },
  { title: 'Ручная работа', text: 'Каждое изделие — авторская сборка', icon: 'hand' },
  { title: 'Доставка по Казахстану', text: 'Астана — в день заказа', icon: 'truck' },
  { title: 'Гарантия подлинности', text: 'Сертификат к каждому камню', icon: 'shield' },
];
---
<section class="trust" id="intro">
  <div class="container">
    <div class="grid">
      {items.map((item) => (
        <div class="item reveal">
          <div class="icon">
            {item.icon === 'gem' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/></svg>
            )}
            {item.icon === 'hand' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-4 0v5"/><path d="M14 10V4a2 2 0 0 0-4 0v6"/><path d="M10 10.5V6a2 2 0 0 0-4 0v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
            )}
            {item.icon === 'truck' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            )}
            {item.icon === 'shield' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            )}
          </div>
          <div>
            <h4>{item.title}</h4>
            <p>{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust {
    padding: clamp(2rem, 4vw, 3rem) 0;
    border-bottom: 1px solid var(--border);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--accent);
  }
  .icon svg {
    width: 22px;
    height: 22px;
  }
  h4 {
    margin: 0 0 0.25rem;
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }
  p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }
</style>
