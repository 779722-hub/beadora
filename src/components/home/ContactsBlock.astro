---
---
<section class="contacts">
  <div class="container">
    <div class="grid">
      <div class="info reveal">
        <span class="eyebrow">Контакты</span>
        <h2>Мы в Астане</h2>

        <div class="rows">
          <div class="row">
            <div class="label">Адрес</div>
            <div class="value">
              Республика Казахстан, г. Астана,<br />
              ул. Брусиловского, 5<br />
              Магазин «ADORA»
            </div>
          </div>
          <div class="row">
            <div class="label">Телефон</div>
            <div class="value">
              <a href="tel:+77787806540" class="call-btn" aria-label="Позвонить в Beadora">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Позвонить нам
              </a>
            </div>
          </div>
          <div class="row">
            <div class="label">Мессенджеры</div>
            <div class="value">
              <a href="https://wa.me/77787806540" target="_blank" rel="noopener">WhatsApp</a> ·
              <a href="https://www.instagram.com/beadora.kz/" target="_blank" rel="noopener">Instagram</a>
            </div>
          </div>
          <div class="row">
            <div class="label">Часы работы</div>
            <div class="value">Ежедневно, 11:00 – 20:00 (Астана)</div>
          </div>
        </div>
      </div>

      <div class="map reveal">
        <iframe
          src="https://yandex.ru/map-widget/v1/?text=%D0%90%D1%81%D1%82%D0%B0%D0%BD%D0%B0%2C%20%D1%83%D0%BB.%20%D0%91%D1%80%D1%83%D1%81%D0%B8%D0%BB%D0%BE%D0%B2%D1%81%D0%BA%D0%BE%D0%B3%D0%BE%2C%205&z=17"
          width="100%"
          height="420"
          frameborder="0"
          title="Карта: Астана, ул. Брусиловского, 5 — магазин Beadora"
          loading="lazy"
          allow="geolocation"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: stretch;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  h2 {
    margin-bottom: 2rem;
  }
  .rows {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    align-items: start;
  }
  @media (max-width: 540px) {
    .row {
      grid-template-columns: 1fr;
    }
  }
  .label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .value {
    color: var(--text);
    line-height: 1.55;
  }
  .value a {
    color: var(--accent);
  }
  .call-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.125rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #e9c185 0%, #c9985a 45%, #a87434 100%);
    color: #fff !important;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    box-shadow: 0 6px 16px color-mix(in srgb, #c9985a 35%, transparent);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .call-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 22px color-mix(in srgb, #c9985a 45%, transparent);
  }
  .call-btn svg {
    width: 16px;
    height: 16px;
  }
  .map {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border);
    min-height: 420px;
    background: var(--surface);
  }
  .map iframe {
    display: block;
    height: 100%;
    min-height: 420px;
  }
</style>
