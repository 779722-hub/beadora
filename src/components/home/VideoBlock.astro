---
export interface Props {
  youtubeId?: string;
  posterImage?: string;
}
const { youtubeId = '', posterImage = '/images/video-poster.jpg' } = Astro.props;
---
<section class="video-block">
  <div class="container">
    <div class="layout">
      <div class="text reveal">
        <span class="eyebrow">История Beadora</span>
        <h2>Как рождаются украшения</h2>
        <p class="lede">
          Каждое изделие собирается вручную — от выбора камня в нашей мастерской в Астане до
          финальной фотосъёмки. Мы работаем только с природными минералами и подбираем
          сочетания, поддерживающие энергетику владельца.
        </p>
        <p class="italic-quote">
          «Камень помнит Землю. Мы помогаем ему говорить с человеком».
        </p>
        <div class="meta-row">
          <a href="/about" class="btn btn-secondary">Подробнее о бренде</a>
          <span class="muted">продолжительность: 1:42</span>
        </div>
      </div>

      <div class="video-frame reveal">
        <div class="video-embed" data-youtube={youtubeId}>
          <img class="poster" src={posterImage} alt="Превью видео «История Beadora»" loading="lazy" />
          <button class="play" type="button" aria-label="Воспроизвести видео">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <polygon points="6 3 21 12 6 21 6 3"/>
            </svg>
          </button>
          {!youtubeId && (
            <span class="placeholder-note">
              Видео скоро появится
            </span>
          )}
        </div>
        <div class="frame-decoration" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .video-block {
    position: relative;
    background: linear-gradient(180deg, transparent 0%, var(--surface) 50%, transparent 100%);
  }
  .layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }
  @media (max-width: 900px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  h2 {
    margin-bottom: 1.25rem;
  }

  .lede {
    font-size: 1.0625rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .italic-quote {
    padding-left: 1rem;
    border-left: 2px solid var(--accent);
    margin-bottom: 2rem;
  }

  .meta-row {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .video-frame {
    position: relative;
  }

  .video-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    overflow: hidden;
    background: var(--surface-raised);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-lg);
    cursor: pointer;
  }
  .poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 999px;
    background: var(--accent);
    color: var(--accent-contrast);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    transition: transform 0.2s ease;
  }
  .video-embed:hover .play {
    transform: translate(-50%, -50%) scale(1.1);
  }
  .play svg {
    width: 30px;
    height: 30px;
    margin-left: 4px;
  }

  .placeholder-note {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .frame-decoration {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 140px;
    height: 140px;
    border-radius: 24px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 100%);
    opacity: 0.14;
    z-index: -1;
  }
</style>

<script>
  function init() {
    document.querySelectorAll<HTMLElement>('[data-youtube]').forEach((embed) => {
      const id = embed.dataset.youtube;
      if (!id) return;
      embed.addEventListener('click', () => {
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        iframe.style.cssText = 'width:100%;height:100%;border:0;position:absolute;inset:0;';
        embed.innerHTML = '';
        embed.appendChild(iframe);
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
