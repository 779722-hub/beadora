---
const slides = [
  { src: '/images/hero.jpg', alt: 'Девушка в национальном костюме с браслетом Beadora из натуральных камней' },
  { src: '/images/lookbook/03.jpg', alt: 'Ожерелье Beadora из лазурита и розового кварца в классическом образе' },
  { src: '/images/lookbook/01.jpg', alt: 'Ожерелье Beadora на манекене в интерьере' },
  { src: '/images/lookbook/05.jpg', alt: 'Украшение Beadora из натуральных камней в интерьере' },
];
---
<section class="hero">
  <div class="hero-media" data-slideshow>
    {slides.map((s, i) => (
      <img
        src={s.src}
        alt={s.alt}
        class:list={['slide', i === 0 ? 'is-active' : '']}
        loading={i === 0 ? 'eager' : 'lazy'}
        fetchpriority={i === 0 ? 'high' : 'auto'}
        width="1440"
        height="900"
      />
    ))}
    <div class="overlay"></div>
  </div>
  <div class="container hero-inner">
    <span class="eyebrow">Beadora · Астана</span>
    <h1>
      Украшения из натуральных камней Beadora —
      <span class="accent">сила камня</span> ручной работы
    </h1>
    <p class="lede">
      Авторские браслеты, серьги и ожерелья из натуральных камней. Ручная работа, подбор по зодиаку,
      гармония в каждой бусине.
    </p>
    <div class="hero-actions">
      <a href="/catalog" class="btn btn-primary btn-lg">Смотреть каталог</a>
      <a href="/quiz" class="btn btn-secondary btn-lg">Подобрать по зодиаку</a>
    </div>
    <a href="#intro" class="scroll-hint" aria-label="Пролистать вниз">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(86vh, 820px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: -1px;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-media .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0;
    transition: opacity 1.4s ease-in-out;
  }
  .hero-media .slide.is-active {
    opacity: 1;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay-hero);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 6rem 0 5rem;
    color: #fff;
    max-width: 1400px;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  h1 {
    color: #fff;
    max-width: 22ch;
    margin-bottom: 1.25rem;
  }
  h1 .accent {
    color: var(--accent-bright);
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
  }

  .lede {
    max-width: 48ch;
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 2rem;
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  .hero .btn-secondary {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .hero .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
    color: var(--accent-bright);
    border-color: var(--accent-bright);
  }

  .scroll-hint {
    position: absolute;
    left: 50%;
    bottom: 2rem;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    animation: bounce 2.4s ease-in-out infinite;
  }
  .scroll-hint svg {
    width: 28px;
    height: 28px;
  }

  @keyframes bounce {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 6px); }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('.hero-media[data-slideshow]');
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLImageElement>('.slide'));
    if (slides.length > 1 && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let i = 0;
      setInterval(() => {
        slides[i].classList.remove('is-active');
        i = (i + 1) % slides.length;
        slides[i].classList.add('is-active');
      }, 5000);
    }
  }
</script>
