---
import Accordion from '../ui/Accordion.astro';

const faq = [
  {
    q: 'Насколько натуральные ваши камни и как долго прослужит браслет?',
    a: 'Все камни — натурального происхождения, мы закупаем их у проверенных поставщиков с сертификатами. При аккуратной носке браслет служит годами: мы рекомендуем снимать его на ночь и избегать контакта с водой и химией.',
  },
  {
    q: 'Каковы магические или целебные свойства ваших камней? Как подобрать камень?',
    a: 'У каждого камня своя энергетика. Мы собираем свойства в разделе <a href="/stones">Камни</a>, а для быстрого подбора есть <a href="/quiz">квиз по знаку зодиака и настроению</a>.',
  },
  {
    q: 'Вы осуществляете доставку по Астане и всему Казахстану?',
    a: 'Да. По Астане — курьером в день заказа или на следующий. По Казахстану — через Kazpost и СДЭК, 2–5 дней в зависимости от города.',
  },
  {
    q: 'Можно ли заказать украшение с моим камнем или в индивидуальном размере?',
    a: 'Да, возможны индивидуальные заказы. Напишите нам в WhatsApp — подберём камни и обсудим эскиз.',
  },
  {
    q: 'Как ухаживать за украшениями?',
    a: 'Протирайте сухой мягкой тканью, храните отдельно в тканевых мешочках. Снимайте перед душем и спортом. Парфюм и кремы наносите до надевания украшения.',
  },
  {
    q: 'Возможен ли возврат или обмен?',
    a: 'В течение 7 дней мы принимаем обмен и возврат украшения, если оно не подошло по размеру или цвету. Украшение должно быть в оригинальной упаковке и без следов носки.',
  },
];
---
<section class="faq-block">
  <div class="container container-narrow">
    <Accordion items={faq} />
  </div>
</section>

<style>
  .faq-block {
    padding-top: clamp(2rem, 4vw, 4rem);
    padding-bottom: clamp(2rem, 4vw, 4rem);
  }
</style>
