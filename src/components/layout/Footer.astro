---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="col brand">
      <a href="/" class="logo" aria-label="Beadora.kz — на главную">
        <img class="logo-mark" src="/images/logo-mark.png" alt="" aria-hidden="true" width="72" height="88" loading="lazy" />
        <span class="logo-text">BEADORA<span class="logo-kz">.kz</span></span>
      </a>
      <p class="muted">
        Авторские украшения из натуральных камней в Казахстане. Ручная работа, подбор по зодиаку, доставка по Астане и всему Казахстану.
      </p>
      <div class="socials">
        <a href="https://www.instagram.com/beadora.kz/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://wa.me/77787806540" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>
        </a>
        <a href="tel:+77787806540" aria-label="Позвонить">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </a>
      </div>
    </div>

    <div class="col">
      <h4>Каталог</h4>
      <ul>
        <li><a href="/catalog/bracelets">Браслеты</a></li>
        <li><a href="/catalog/necklaces">Ожерелья и колье</a></li>
        <li><a href="/catalog/earrings">Серьги</a></li>
        <li><a href="/catalog/sets">Комплекты</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Полезное</h4>
      <ul>
        <li><a href="/stones">Камни и свойства</a></li>
        <li><a href="/quiz">Подобрать по зодиаку</a></li>
        <li><a href="/reference">Как отличить натуральные камни</a></li>
        <li><a href="/about">О бренде</a></li>
      </ul>
    </div>

    <div class="col">
      <h4>Контакты</h4>
      <address>
        Республика Казахстан, г. Астана,<br />
        ул. Брусиловского, 5<br />
        Магазин «ADORA»
      </address>
      <a href="tel:+77787806540" class="phone">+7 (778) 780-65-40</a>
    </div>
  </div>

  <div class="container copyright">
    <span>© {year} «Beadora». Все права защищены.</span>
    <nav>
      <a href="/privacy">Политика конфиденциальности</a>
      <a href="/offer">Оферта</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 3rem 0 1.5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
  }
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 540px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text);
    text-decoration: none;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
  }
  .logo-mark {
    height: 56px;
    width: auto;
    display: block;
  }
  .logo-text {
    font-size: 1.5rem;
    letter-spacing: 0.08em;
  }
  .logo-kz {
    color: var(--accent);
    font-weight: 400;
    font-size: 0.875em;
  }

  .brand p {
    margin: 1rem 0 1.5rem;
    max-width: 30rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .socials {
    display: flex;
    gap: 0.5rem;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .socials a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .socials svg {
    width: 18px;
    height: 18px;
  }

  .col h4 {
    margin: 0 0 1rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .col ul a {
    color: var(--text);
    font-size: 0.9375rem;
  }

  address {
    font-style: normal;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .phone {
    display: inline-block;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .copyright {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 2rem;
    margin-top: 2.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
    color: var(--text-subtle);
    flex-wrap: wrap;
  }
  .copyright nav {
    display: flex;
    gap: 1.5rem;
  }
  .copyright a {
    color: var(--text-subtle);
  }
  .copyright a:hover {
    color: var(--accent);
  }
</style>
