---
import Base from '../layouts/Base.astro';
import ContactsBlock from '../components/home/ContactsBlock.astro';
---
<Base title="Контакты Beadora.kz — Астана, Брусиловского 5" description="Адрес магазина, карта, телефон и мессенджеры Beadora. Как добраться и режим работы.">
  <section class="contacts-hero">
    <div class="container container-narrow">
      <nav class="crumbs">
        <a href="/">Главная</a> / <span>Контакты</span>
      </nav>
      <h1>Контакты</h1>
      <p class="lede">
        Заходите в наш магазин «ADORA» в центре Астаны. Будем рады подобрать украшение
        лично и рассказать о свойствах камней.
      </p>
    </div>
  </section>
  <ContactsBlock />
</Base>

<style>
  .contacts-hero {
    padding: 3rem 0 1rem;
  }
  .crumbs {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: var(--text-muted);
  }
  .lede {
    color: var(--text-muted);
    font-size: 1.0625rem;
    max-width: 60ch;
  }
</style>
