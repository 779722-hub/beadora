---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import { STONES, ZODIAC, productsByStone } from '../../lib/data';
import { breadcrumbListJsonLd } from '../../lib/seo';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return STONES.map((s) => ({
    params: { stone: s.slug },
    props: { stone: s },
  }));
};

const { stone } = Astro.props;
const products = productsByStone(stone.slug);
const affinitySigns = ZODIAC.filter((z) => stone.zodiac_affinity.includes(z.slug));

const siteOrigin = (Astro.site ?? new URL('https://beadora.kz/')).origin;
const breadcrumb = breadcrumbListJsonLd(
  [
    { name: 'Главная', url: '/' },
    { name: 'Камни', url: '/stones' },
    { name: stone.title, url: `/stones/${stone.slug}` },
  ],
  siteOrigin,
);
---
<Base
  title={`${stone.title} — свойства, значение, украшения · Beadora.kz`}
  description={`${stone.title}: ${stone.short}. ${stone.description.slice(0, 120)}…`}
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  <section class="stone-hero">
    <div class="container">
      <nav class="crumbs">
        <a href="/">Главная</a> / <a href="/stones">Камни</a> / <span>{stone.title}</span>
      </nav>
      <div class="layout">
        <div class="image-block">
          <div class="swatch-big" style={`--stone-color: ${stone.color}`}>
            <span>◆</span>
          </div>
        </div>
        <div class="info">
          <h1>{stone.title}</h1>
          <p class="lede">{stone.short}</p>
          <div class="props-row">
            {stone.properties.map((p) => <span class="chip chip-accent">{p}</span>)}
          </div>
          <div class="description" set:html={stone.description.replace(/\n/g, '<br/>')} />
        </div>
      </div>
    </div>
  </section>

  {affinitySigns.length > 0 && (
    <section class="affinity">
      <div class="container">
        <h2>Подходит знакам</h2>
        <div class="signs">
          {affinitySigns.map((z) => (
            <a href={`/catalog/zodiac/${z.slug}`} class="sign">
              <span class="sym" aria-hidden="true">{z.symbol}{'\uFE0E'}</span>
              <strong>{z.title}</strong>
              <span class="dates">{z.dates}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {products.length > 0 && (
    <section>
      <div class="container">
        <h2>Украшения с {stone.title.toLowerCase() === stone.title ? stone.title : stone.title.toLowerCase()}</h2>
        <div class="grid">
          {products.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</Base>

<style>
  .stone-hero {
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }
  .crumbs {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .crumbs a {
    color: var(--text-muted);
  }
  .layout {
    display: grid;
    grid-template-columns: 0.6fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }
  @media (max-width: 820px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }

  .swatch-big {
    aspect-ratio: 1 / 1;
    border-radius: 28px;
    background: var(--stone-color);
    box-shadow: inset 0 -16px 32px rgba(0, 0, 0, 0.3), inset 0 16px 32px rgba(255, 255, 255, 0.2);
    border: 3px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 4rem;
  }

  h1 {
    margin: 0 0 0.5rem;
  }
  .lede {
    color: var(--text-muted);
    font-size: 1.125rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    margin-bottom: 1.25rem;
  }
  .props-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .description {
    color: var(--text);
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .affinity {
    background: var(--surface);
  }
  .affinity h2 {
    margin-bottom: 1.5rem;
  }
  .signs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }
  .sign {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 1.25rem;
    border-radius: 16px;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    text-align: center;
    transition: border-color 0.2s ease;
  }
  .sign:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .sign .sym {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    font-family: 'Playfair Display', 'Times New Roman', serif;
    font-variant-emoji: text;
    font-size: 1.75rem;
    line-height: 1;
    background: linear-gradient(135deg, #e9c185 0%, #c9985a 45%, #a87434 100%);
    color: #fff;
    box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.15), 0 2px 6px rgba(184, 137, 71, 0.2);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }
  .sign strong {
    font-size: 1.125rem;
  }
  .dates {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  h2 {
    margin: 0 0 1rem;
  }
</style>
