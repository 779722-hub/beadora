---
import Base from '../../layouts/Base.astro';
import { STONES } from '../../lib/data';
---
<Base
  title="Камни и их свойства — Beadora.kz"
  description="Натуральные камни, которые мы используем в украшениях: аметист, цитрин, лазурит, агат, лунный камень и другие. Энергетика, подбор по знаку зодиака."
>
  <section class="stones-hero">
    <div class="container container-narrow">
      <nav class="crumbs">
        <a href="/">Главная</a> / <span>Камни</span>
      </nav>
      <h1>Камни и их свойства</h1>
      <p class="lede">
        Каждый камень несёт свою энергию. Здесь — справочник минералов, с которыми мы работаем:
        их характер, астрологическая совместимость и лечебные традиции.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid">
        {STONES.map((s) => (
          <a class="stone-tile" href={`/stones/${s.slug}`}>
            <img class="photo" src={`/images/stones/${s.slug}.jpg`} alt={s.title} width="320" height="220" loading="lazy" />
            <h3>{s.title}</h3>
            <p class="short">{s.short}</p>
            <p class="props">
              {s.properties.slice(0, 3).map((p) => <span class="chip">{p}</span>)}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .stones-hero {
    padding: 3rem 0 2rem;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }
  .crumbs {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: var(--text-muted);
  }
  .lede {
    max-width: 60ch;
    margin: 0 auto;
    color: var(--text-muted);
    font-size: 1.0625rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .stone-tile {
    padding: 0 0 1.5rem;
    border-radius: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
    overflow: hidden;
  }
  .stone-tile:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    color: var(--text);
  }
  .stone-tile .photo {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-bottom: 1px solid var(--border);
  }
  .stone-tile h3,
  .stone-tile .short,
  .stone-tile .props {
    padding-inline: 1.5rem;
  }
  h3 {
    margin: 0;
    font-size: 1.25rem;
  }
  .short {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
    flex: 1;
  }
  .props {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 0;
  }
</style>
