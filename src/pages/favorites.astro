---
import Base from '../layouts/Base.astro';
import { PRODUCTS } from '../lib/data';
---
<Base title="Избранное — Beadora.kz" description="Украшения, которые вам понравились.">
  <section class="favs">
    <div class="container">
      <nav class="crumbs">
        <a href="/">Главная</a> / <span>Избранное</span>
      </nav>
      <h1>Избранное</h1>
      <div id="favoritesContent">
        <p class="loading">Загрузка…</p>
      </div>
    </div>
  </section>

  <!-- Hidden data pool for client-side -->
  <script
    type="application/json"
    id="productPool"
    set:html={JSON.stringify(
      PRODUCTS.map((p) => ({
        sku: p.sku,
        name: p.name,
        categoryTitle: p.categoryTitle,
        price: p.price,
        image: p.images[0],
        stones: p.stones,
      }))
    )}
  />
</Base>

<style>
  .favs {
    padding: 2rem 0 4rem;
  }
  .crumbs {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: var(--text-muted);
  }
  h1 {
    margin-bottom: 2rem;
  }
  .loading {
    color: var(--text-muted);
    text-align: center;
    padding: 2rem;
  }
</style>

<script>
  import { readFavorites, toggleFavorite } from '../lib/favorites';
  import { formatPrice } from '../lib/data';

  interface Lite {
    sku: string;
    name: string;
    categoryTitle: string;
    price: number;
    image: string;
    stones: string[];
  }

  function render() {
    const poolEl = document.getElementById('productPool');
    const container = document.getElementById('favoritesContent');
    if (!poolEl || !container) return;
    const pool: Lite[] = JSON.parse(poolEl.textContent ?? '[]');
    const favSkus = readFavorites();
    const items = pool.filter((p) => favSkus.includes(p.sku));

    if (items.length === 0) {
      container.innerHTML = `
        <div style="padding:3rem;text-align:center;border:1px dashed var(--border);border-radius:16px;">
          <p style="color:var(--text-muted);margin-bottom:1rem;">Пока ничего не добавлено в избранное</p>
          <a href="/catalog" class="btn btn-primary">Открыть каталог</a>
        </div>
      `;
      return;
    }

    container.innerHTML = `
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.25rem;">
        ${items.map((p) => `
          <article style="background:var(--surface);border:1px solid var(--border);border-radius:16px;overflow:hidden;">
            <a href="/product/${p.sku}" style="display:block;aspect-ratio:1/1;overflow:hidden;">
              <img src="${p.image}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
            </a>
            <div style="padding:1rem;display:flex;flex-direction:column;gap:0.375rem;">
              <span style="font-size:0.75rem;color:var(--text-subtle);letter-spacing:0.08em;text-transform:uppercase;">Арт. ${p.sku}</span>
              <a href="/product/${p.sku}" style="color:var(--text);text-decoration:none;">
                <strong style="font-family:'Playfair Display',serif;font-size:1.0625rem;">${p.categoryTitle} «${p.name}»</strong>
              </a>
              <span style="color:var(--accent);font-weight:700;font-family:'Playfair Display',serif;font-size:1.125rem;">${formatPrice(p.price)}</span>
              <button class="btn btn-ghost btn-sm" data-remove="${p.sku}" style="margin-top:0.5rem;align-self:flex-start;">Убрать из избранного</button>
            </div>
          </article>
        `).join('')}
      </div>
    `;

    container.querySelectorAll<HTMLElement>('[data-remove]').forEach((btn) => {
      btn.addEventListener('click', () => {
        toggleFavorite(btn.dataset.remove!);
        render();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
  window.addEventListener('favorites:change', render);
</script>
