---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import { PRODUCTS, CATEGORIES } from '../../lib/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return CATEGORIES.map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
};

const { category } = Astro.props;
const categoryMap: Record<string, string> = {
  bracelets: 'bracelet',
  necklaces: 'necklace',
  earrings: 'earrings',
  sets: 'set',
};
const filter = categoryMap[category.slug];
const items = PRODUCTS.filter((p) => p.category === filter);
---
<Base
  title={`${category.title} — Beadora.kz`}
  description={category.description}
>
  <section class="cat-hero">
    <div class="container">
      <nav class="crumbs">
        <a href="/">Главная</a> / <a href="/catalog">Каталог</a> / <span>{category.title}</span>
      </nav>
      <h1>{category.title}</h1>
      <p class="lede">{category.description}</p>
      <p class="count">{items.length} изделий</p>
    </div>
  </section>

  <section>
    <div class="container">
      {items.length === 0 ? (
        <p class="empty">В этой категории пока нет товаров. Загляните позже.</p>
      ) : (
        <div class="grid">
          {items.map((p) => <ProductCard product={p} />)}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .cat-hero {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--border);
  }
  .crumbs {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: var(--text-muted);
  }
  .crumbs a:hover {
    color: var(--accent);
  }
  .crumbs span {
    color: var(--text);
  }
  .lede {
    max-width: 60ch;
    color: var(--text-muted);
    font-size: 1.0625rem;
  }
  .count {
    color: var(--accent);
    font-weight: 600;
    margin-top: 0.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .empty {
    padding: 3rem;
    text-align: center;
    color: var(--text-muted);
  }
</style>
