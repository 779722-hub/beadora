---
import Base from '../layouts/Base.astro';
---
<Base title="Страница не найдена — Beadora.kz" noFab={true}>
  <section class="nf">
    <div class="container container-narrow">
      <div class="big">404</div>
      <h1>Страница потерялась в пустыне камней</h1>
      <p>
        Мы не смогли найти то, что вы искали. Возможно, ссылка устарела или страница переехала.
      </p>
      <div class="actions">
        <a href="/" class="btn btn-primary btn-lg">На главную</a>
        <a href="/catalog" class="btn btn-secondary btn-lg">В каталог</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf {
    padding: 5rem 0;
    text-align: center;
  }
  .big {
    font-family: 'Playfair Display', serif;
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 1rem;
    text-shadow: 0 0 60px rgba(212, 175, 55, 0.25);
  }
  h1 {
    margin-bottom: 1rem;
  }
  p {
    color: var(--text-muted);
    max-width: 40ch;
    margin: 0 auto 2rem;
    font-size: 1.0625rem;
  }
  .actions {
    display: inline-flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
